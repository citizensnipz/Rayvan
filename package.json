{
  "name": "rayvan",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Local-first infrastructure control plane for small teams and AI coding agents",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:desktop": "pnpm --filter @rayvan/desktop tauri dev",
    "dev:mcp": "pnpm --filter @rayvan/mcp-server dev",
    "daemon:dev": "pnpm --filter @rayvan/daemon dev",
    "mcp:dev": "pnpm --filter @rayvan/mcp-server dev",
    "desktop:dev": "pnpm --filter @rayvan/desktop tauri dev",
    "mcp:inspect": "pnpm dlx @modelcontextprotocol/inspector",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "vitest run --config vitest.config.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cargo:check": "node tooling/scripts/ensure-tauri-frontend-dist.mjs && cargo check --workspace",
    "cargo:test": "node tooling/scripts/ensure-tauri-frontend-dist.mjs && cargo test --workspace",
    "validate:harness": "node tooling/scripts/validate-harness.mjs",
    "check:harness": "pnpm validate:harness && git diff --check",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm cargo:check && pnpm cargo:test && pnpm check:harness",
    "prepush": "bash tooling/scripts/prepush.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
