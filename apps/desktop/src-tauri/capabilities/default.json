{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for the Rayvan desktop shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/rayvand",
          "sidecar": true,
          "args": ["serve"]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/rayvand",
          "sidecar": true,
          "args": ["serve"]
        }
      ]
    }
  ]
}
